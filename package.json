{
  "name": "anime-list",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "analyze": "ANALYZE=true next build",
    "postinstall": "patch-package",
    "seed:firestore": "node scripts/seed-firestore.js",
    "gen-trans": "node scripts/generate-translations.cjs",
    "test": "firebase emulators:exec --only firestore --project=demo-animelegacy \"vitest run\"",
    "test:watch": "firebase emulators:exec --only firestore --project=demo-animelegacy \"vitest\""
  },
  "dependencies": {
    "firebase": "^10.12.0",
    "firebase-admin": "^12.1.0",
    "lucide-react": "^1.8.0",
    "next": "^14.2.3",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-switch-lang": "^1.0.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "3",
    "@next/bundle-analyzer": "^16.2.4",
    "dotenv": "^17.4.2",
    "firebase-tools": "13",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "patch-package": "^8.0.1",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
