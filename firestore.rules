rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anime catalog cache. Read public; writes restricted to authenticated
    // users with the exact field whitelist used by `ensureAnimeCatalog` and
    // `useTranslatedText`. Prevents random users from writing arbitrary
    // 1MB blobs to inflate Firestore bills.
    //
    // Catalog fields come from lib/services/animeCatalog.js::buildAnimeCatalogPayload;
    // translation fields come from hooks/useTranslatedText.js with
    // cacheCollection='anime'.
    match /anime/{animeId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly([
            'animeId', 'title',
            'posterUrl', 'bannerUrl',
            'year', 'season', 'type', 'status',
            'episodesTotal', 'durationMin',
            'genres', 'studios', 'malScore',
            'updatedAt',
            'synopsisByLang', 'backgroundByLang'
        ]);
    }

    // Translation caches for biographies (characters/people) and studio
    // "about". Same shape: writers must be authenticated; the only writable
    // payload is the translation maps. Caps the per-doc size to prevent
    // abuse via 1MB junk writes.
    match /characters/{characterId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['biographyByLang'])
        && request.resource.data.biographyByLang is map;
    }

    match /people/{personId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['biographyByLang'])
        && request.resource.data.biographyByLang is map;
    }

    match /studios/{studioId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['aboutByLang'])
        && request.resource.data.aboutByLang is map;
    }

    match /characterStats/{characterId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['favoritesCount'])
        && request.resource.data.favoritesCount is int
        && request.resource.data.favoritesCount >= 0;
    }

    match /voiceStats/{voiceId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['favoritesCount'])
        && request.resource.data.favoritesCount is int
        && request.resource.data.favoritesCount >= 0;
    }

    match /studioStats/{studioId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['favoritesCount'])
        && request.resource.data.favoritesCount is int
        && request.resource.data.favoritesCount >= 0;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /anime/{animeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /activity/{activityId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /list/{animeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /collections/{collectionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /favoriteCharacters/{characterId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /favoriteVoices/{voiceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /favoriteStudios/{studioId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
