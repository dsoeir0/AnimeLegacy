rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /anime/{animeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Catalogue-style caches for translated biographies. Mirror the anime/{id}
    // pattern: anyone can read (so anonymous visitors see previously-translated
    // text), only authenticated users can write (so they contribute to the
    // shared cache after their first view). Used by the `useTranslatedText`
    // hook with cacheCollection = 'characters' | 'people'.
    match /characters/{characterId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /people/{personId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /characterStats/{characterId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['favoritesCount'])
        && request.resource.data.favoritesCount is int
        && request.resource.data.favoritesCount >= 0;
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && !exists(/databases/$(database)/documents/usernames/$(username))
        && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /anime/{animeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /activity/{activityId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /list/{animeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /collections/{collectionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /favoriteCharacters/{characterId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
